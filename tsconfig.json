{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": [
    "./hardhat.config.ts",
    "./ignition/**/*.ts",
    "./test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "frontend"
  ]
}
